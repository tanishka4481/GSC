# =============================================================================
# PROVCHAIN — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.
# =============================================================================

# --- App Settings ---
APP_NAME=PROVCHAIN
APP_VERSION=0.1.0
DEBUG=true

# --- Google Cloud Platform ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GCP_REGION=asia-south1

# --- Gemini API ---
GEMINI_API_KEY=your-gemini-api-key

# --- Vertex AI Matching Engine ---
VERTEX_INDEX_ID=your-vertex-index-id
VERTEX_ENDPOINT_ID=your-vertex-endpoint-id

# --- Firebase ---
FIREBASE_CREDENTIALS_PATH=path/to/serviceAccountKey.json
FIRESTORE_DATABASE_ID=default

# --- IPFS (Pinata) ---
PINATA_JWT=your-pinata-jwt-token
PINATA_API_URL=https://api.pinata.cloud

# --- SerpApi Search ---
SERPAPI_API_KEY=your-serpapi-api-key

# --- Google Custom Search (legacy, commented out) ---
# CUSTOM_SEARCH_API_KEY=your-custom-search-api-key
# CUSTOM_SEARCH_CX=your-custom-search-cx-id

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# --- Monitoring (Phase 3) ---
# SCAN_MAX_CANDIDATES=10
# SCAN_IMAGE_DOWNLOAD_TIMEOUT=10.0
# ALERT_RISK_THRESHOLD=0.7
# GOOGLE_SEARCH_RESULTS_PER_QUERY=10
# GOOGLE_SEARCH_DAILY_QUOTA=100
